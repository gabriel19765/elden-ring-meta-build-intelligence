      "title": "Top 10 Armas por Win Rate Real-Time",
      "type": "barchart",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT w.name as weapon, AVG(r.win_rate) as avg_win_rate FROM real_time_rankings r JOIN weapons w ON r.weapon_id = w.weapon_id GROUP BY w.name ORDER BY avg_win_rate DESC LIMIT 10;",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 80
          },
          "unit": "percent"
        }
