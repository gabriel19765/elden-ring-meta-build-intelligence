      "title": "Historial Reciente de Alertas de Meta-Shift",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT w.name as Arma, b.name as Jefe, m.shift_type as Cambio, m.previous_popularity as \"WR Prev\", m.current_popularity as \"WR Curr\", m.change_percentage as \"Cambio %\", m.detected_at as \"Detectado\" FROM meta_shifts m JOIN weapons w ON m.weapon_id = w.weapon_id JOIN bosses b ON m.boss_id = b.boss_id ORDER BY m.detected_at DESC LIMIT 10;",
          "refId": "A"
        }
      ]
    }
