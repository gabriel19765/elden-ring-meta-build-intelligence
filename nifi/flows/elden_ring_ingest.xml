<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<template encoding-version="1.3">
    <description>Elden Ring Fan API ingestion flow to Apache Kafka</description>
    <groupId>elden-ring-meta-ingest</groupId>
    <name>Elden Ring Ingestion Pipeline</name>
    <snippet>
        <connections>
            <id>conn-1</id>
            <source>
                <groupId>elden-ring-meta-ingest</groupId>
                <id>proc-fetch-weapons</id>
                <type>PROCESSOR</type>
            </source>
            <destination>
                <groupId>elden-ring-meta-ingest</groupId>
                <id>proc-publish-kafka</id>
                <type>PROCESSOR</type>
            </destination>
            <name>Weapons to Kafka</name>
        </connections>
        
        <processors>
            <!-- Fetch Weapons from Elden Ring REST Fan API -->
            <id>proc-fetch-weapons</id>
            <name>Fetch Elden Ring Weapons</name>
            <type>org.apache.nifi.processors.standard.InvokeHTTP</type>
            <config>
                <properties>
                    <entry>
                        <key>HTTP Method</key>
                        <value>GET</value>
                    </entry>
                    <entry>
                        <key>Remote URL</key>
                        <value>https://eldenring.fanapis.com/api/weapons?limit=100</value>
                    </entry>
                </properties>
            </config>
        </processors>
        
        <processors>
            <!-- Publish Weapons to Kafka Topic -->
            <id>proc-publish-kafka</id>
            <name>Publish to Kafka</name>
            <type>org.apache.nifi.processors.kafka.pubsub.PublishKafka_2_6</type>
            <config>
                <properties>
                    <entry>
                        <key>bootstrap.servers</key>
                        <value>kafka:29092</value>
                    </entry>
                    <entry>
                        <key>topic</key>
                        <value>weapon-stats</value>
                    </entry>
                </properties>
            </config>
        </processors>
    </snippet>
</template>
